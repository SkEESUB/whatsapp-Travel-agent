# ============================================
# WhatsApp Travel Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ============================================
# Server Configuration
# ============================================
# Application port (default: 3000)
PORT=3000

# Node environment (development, staging, production)
NODE_ENV=production

# ============================================
# WhatsApp Cloud API
# ============================================
# Get these from Meta Developers Console: https://developers.facebook.com/
# WhatsApp Access Token (Permanent token recommended for production)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# WhatsApp Phone Number ID (from Meta dashboard)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# WhatsApp App Secret (for webhook verification)
WHATSAPP_APP_SECRET=your_app_secret_here

# WhatsApp Verify Token (custom token for webhook setup)
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# ============================================
# Gemini AI (Google)
# ============================================
# Get API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (gemini-2.5-flash recommended)
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# OpenAI (Optional - Fallback)
# ============================================
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# Redis Configuration
# ============================================
# Redis host (use service name in Docker, localhost for local dev)
REDIS_HOST=localhost

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis password (if using authentication)
# REDIS_PASSWORD=your_redis_password

# ============================================
# MongoDB Configuration
# ============================================
# MongoDB connection string
# For local development: mongodb://localhost:27017/travelbot
# For Docker: mongodb://mongodb:27017/travelbot
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/travelbot
MONGODB_URI=mongodb://localhost:27017/travelbot

# ============================================
# Razorpay (Payment Gateway)
# ============================================
# Get keys from Razorpay Dashboard: https://dashboard.razorpay.com/
# Use test keys for development, live keys for production
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Razorpay webhook secret (for payment verification)
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Affiliate Program IDs
# ============================================
# MakeMyTrip Affiliate ID (register at: https://affiliate.makemytrip.com/)
MMT_AFFILIATE_ID=your_mmt_affiliate_id

# Goibibo Affiliate ID
GOIBIBO_AFFILIATE_ID=your_goibibo_affiliate_id

# Booking.com Affiliate ID (join at: https://www.booking.com/affiliate-program)
BOOKING_AFFILIATE_ID=your_booking_affiliate_id

# RedBus Affiliate ID
REDBUS_AFFILIATE_ID=your_redbus_affiliate_id

# ============================================
# Admin Dashboard
# ============================================
# Admin API key (generate a secure random string)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_API_KEY=your_secure_admin_api_key_here

# ============================================
# Security
# ============================================
# JWT secret for authentication (if implementing user auth)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Session secret
SESSION_SECRET=your_session_secret_here

# Phone number hash salt
PHONE_HASH_SALT=your_phone_hash_salt_here

# ============================================
# Logging
# ============================================
# Log level (error, warn, info, http, verbose, debug, silly)
LOG_LEVEL=info

# Log file directory
LOG_DIR=logs

# ============================================
# Rate Limiting
# ============================================
# Rate limit window (in seconds)
RATE_LIMIT_WINDOW=60

# Max requests per window
RATE_LIMIT_MAX=30

# ============================================
# Queue Configuration (BullMQ)
# ============================================
# Queue name
QUEUE_NAME=whatsapp-messages

# Queue concurrency (number of parallel jobs)
QUEUE_CONCURRENCY=10

# ============================================
# Cache Configuration
# ============================================
# Cache TTL for hotels (in seconds, default: 21600 = 6 hours)
CACHE_TTL_HOTELS=21600

# Cache TTL for transport (in seconds, default: 3600 = 1 hour)
CACHE_TTL_TRANSPORT=3600

# Cache TTL for itinerary (in seconds, default: 43200 = 12 hours)
CACHE_TTL_ITINERARY=43200

# Cache TTL for weather (in seconds, default: 10800 = 3 hours)
CACHE_TTL_WEATHER=10800

# Cache TTL for food (in seconds, default: 86400 = 24 hours)
CACHE_TTL_FOOD=86400

# Cache TTL for budget (in seconds, default: 21600 = 6 hours)
CACHE_TTL_BUDGET=21600

# ============================================
# Feature Flags
# ============================================
# Enable/disable features
ENABLE_WEATHER=true
ENABLE_FOOD_GUIDE=true
ENABLE_BOOKING_LINKS=true
ENABLE_MULTI_LANGUAGE=true
ENABLE_AFFILIATE_TRACKING=true

# ============================================
# Optional: Email Configuration (for notifications)
# ============================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_email_password

# ============================================
# Optional: Sentry Error Tracking
# ============================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ============================================
# Optional: New Relic Monitoring
# ============================================
# NEW_RELIC_LICENSE_KEY=your_new_relic_license_key

# ============================================
# Docker-Specific (Auto-set in docker-compose)
# ============================================
# These are automatically set in docker-compose.yml
# REDIS_HOST=redis
# MONGODB_URI=mongodb://mongodb:27017/travelbot

# ============================================
# Notes
# ============================================
# 1. NEVER commit .env file to Git
# 2. Use different values for development and production
# 3. Rotate API keys regularly
# 4. Use strong passwords and secrets
# 5. Store production secrets in a secure vault
# 6. Test with test API keys before going live
# 7. Enable 2FA on all third-party services
